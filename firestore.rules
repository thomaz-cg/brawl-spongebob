rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Ranking: leitura pública, escrita apenas com campos válidos
    match /ranking/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(["name", "wins", "updatedAt"])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 16
                    && request.resource.data.wins == 1;
      allow update: if request.resource.data.wins == resource.data.wins + 1
                    && request.resource.data.name == resource.data.name;
    }
  }
}
